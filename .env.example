# Required for auth
JWT_SECRET=generate-a-random-secret-here

# Resend API key (optional in dev — OTPs print to console without it)
RESEND_API_KEY=

# Email sender (requires verified domain in Resend)
EMAIL_FROM=MSV Hub <noreply@yourdomain.com>

# Primary TO email(s), comma-separated (required in production)
SEED_TO_EMAILS=you@example.com

# Additional TO emails (comma-separated)
EXTRA_TO_EMAILS=

# StartGG API token
STARTGG_TOKEN=

# Discord bot token (for pre-tournament setup and community commands)
DISCORD_BOT_TOKEN=

# Discord application ID — found in Developer Portal → General Information
DISCORD_APP_ID=

# Discord application public key — found in Developer Portal → General Information
# Required for slash command signature verification
DISCORD_PUBLIC_KEY=

# Discord guild (server) ID — right-click server icon → Copy Server ID
DISCORD_GUILD_ID=

# Discord channel IDs (defaults match MSV's server; override if needed)
# Forum channel where waitlist posts live
DISCORD_CHANNEL_WAITLIST=1193295598166737118
# Forum channel for top-8 graphic requests
DISCORD_CHANNEL_TOP8=1193298151503831163
# Forum channel for dropping-out posts
DISCORD_CHANNEL_DROPOUT=1193304496583999588
# Forum channel for priority-registration posts
DISCORD_CHANNEL_PRI_REG=1194324348014698496
# Text channel for live registration announcements (@everyone)
DISCORD_CHANNEL_ANNOUNCE=1066863301885173800
# Text channel for test announcements
DISCORD_CHANNEL_TEST_ANNOUNCE=1317322763043864616

# Upstash Redis (for tournament state persistence)
# Create a free database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Secret for the scheduled cron endpoint (POST /api/discord/cron)
# Must match the CRON_SECRET GitHub Actions secret
CRON_SECRET=generate-a-random-secret-here

# Public hostname of the app (no https://) — used to build the live-page link in round announcements
APP_URL=your-app.vercel.app

# GitHub PAT with 'workflow' scope — used to auto-update the cron schedule when reg time changes
GITHUB_PAT=
# GitHub repo in owner/repo format
GITHUB_REPO=danbugs/msv-hub
