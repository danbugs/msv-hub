# Required for auth
JWT_SECRET=generate-a-random-secret-here

# Resend API key (optional in dev — OTPs print to console without it)
RESEND_API_KEY=

# Email sender (requires verified domain in Resend)
EMAIL_FROM=MSV Hub <noreply@yourdomain.com>

# Primary TO email(s), comma-separated (required in production)
SEED_TO_EMAILS=you@example.com

# Additional TO emails (comma-separated)
EXTRA_TO_EMAILS=

# StartGG API token
STARTGG_TOKEN=

# Discord bot token (for pre-tournament setup)
DISCORD_BOT_TOKEN=

# Upstash Redis (for tournament state persistence)
# Create a free database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
